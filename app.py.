def calcular_totales(df):
    meses = ["Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre", "Enero", "Febrero", "Marzo"]
    def fila_total(row):
        precio = PRECIOS.get(row['Categoría'], 0.0)
        return sum(row[meses]) * precio
    df['Total Pagado (€)'] = df.apply(fila_total, axis=1)
    return df

